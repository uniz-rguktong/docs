  "keyFeatures": [
    "Role-based access control with student, faculty, caretaker, warden, dean, director, and security roles",
    "Multi-level outpass and outing approval workflow",
    "Real-time grades and attendance tracking with Redis caching",
    "Bulk Excel upload for grades, attendance, and student rosters",
    "Campus security gate check-in/check-out with live student presence tracking",
    "OTP-based password reset via email",
    "PWA (Progressive Web App) installable on iOS, Android, and desktop",
    "Live announcements and banner management system",
    "Grievance submission and management",
    "Semester registration and subject allocation workflow"
  ],
